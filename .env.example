# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code Configuration
# The bot invokes the `claude` CLI — authenticate with `claude login` first.
# Path to claude binary (defaults to 'claude' on PATH)
# CLAUDE_EXECUTABLE=/Users/username/.local/bin/claude

# Working Directory Configuration
# Base directory for relative paths (e.g., /Users/username/projects/)
# If set, you can use "cwd project-name" instead of full paths
BASE_DIRECTORY=/Users/username/projects/
# Default project — determines which CLAUDE.md, plugins, and settings are loaded
DEFAULT_WORKING_DIRECTORY=your-project

# Optional: API key auth (alternative to `claude login`)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# Development
# DEBUG=true
